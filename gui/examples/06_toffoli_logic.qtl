// Test 6 - Porte de Toffoli (AND quantique / CCX) et logique conditionnelle
// Niveau : intermediaire+ (porte a 3 qubits, if en cascade)
qreg q[3];
creg c[3];

x q[0];
x q[1];

toffoli q[0], q[1], q[2];

barrier q[0], q[1], q[2];

measure q[0] -> c[0];
measure q[1] -> c[1];
measure q[2] -> c[2];

// q[2] doit valoir 1 = q[0] AND q[1]
if (c[2] == 1) print state;
if (c[2] == 0) print probs;

print probs;
