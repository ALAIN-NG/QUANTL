Grammaire

    0 $accept: programme $end

    1 programme: ε
    2          | liste_instructions

    3 liste_instructions: instruction
    4                   | liste_instructions instruction

    5 instruction: decl_qreg
    6            | decl_creg
    7            | instr_porte
    8            | instr_mesure
    9            | instr_if
   10            | instr_print
   11            | instr_barrier
   12            | instr_repeat

   13 decl_qreg: QREG IDENT '[' ENTIER ']' ';'

   14 decl_creg: CREG IDENT '[' ENTIER ']' ';'

   15 instr_porte: PORTE1Q IDENT '[' ENTIER ']' ';'
   16            | PORTE1Q IDENT '[' ENTIER ']' '(' angle ')' ';'
   17            | PORTEROT IDENT '[' ENTIER ']' '(' angle ')' ';'
   18            | PORTE2Q IDENT '[' ENTIER ']' ',' IDENT '[' ENTIER ']' ';'
   19            | TOFFOLI IDENT '[' ENTIER ']' ',' IDENT '[' ENTIER ']' ',' IDENT '[' ENTIER ']' ';'

   20 instr_mesure: MEASURE IDENT '[' ENTIER ']' FLECHE IDENT '[' ENTIER ']' ';'

   21 instr_if: IF '(' IDENT '[' ENTIER ']' EGALEGAL ENTIER ')' instruction

   22 instr_print: PRINT IDENT ';'

   23 instr_barrier: BARRIER ';'
   24              | BARRIER liste_ref_qubits ';'

   25 liste_ref_qubits: IDENT '[' ENTIER ']'
   26                 | liste_ref_qubits ',' IDENT '[' ENTIER ']'

   27 instr_repeat: REPEAT '(' ENTIER ')' '{' liste_instructions '}'

   28 angle: FLOTTANT
   29      | ENTIER


